    <div class="container" style="max-width: 900px;">
        <div class="logo">
            <h2>🔍 Consulta de Estado de Radicados</h2>
            <p class="text-muted">Sistema de Gestión Documental - Orfeo</p>
        </div>
        
        <div class="form-section">
            <form method="POST" action="">
                <div class="form-group">
                    <label for="numeroRadicado">Número de Radicado:</label>
                    <input type="text" class="form-control" id="numeroRadicado" name="numeroRadicado" 
                           placeholder="Ej: 2026009000000162" value="<?= isset($_POST['numeroRadicado']) ? htmlspecialchars($_POST['numeroRadicado']) : '' ?>" required>
                </div>
                
                <div class="form-group">
                    <label for="codigoVerificacion">Código de Verificación:</label>
                    <input type="text" class="form-control" id="codigoVerificacion" name="codigoVerificacion" 
                           placeholder="Ingrese su código de verificación" value="<?= isset($_POST['codigoVerificacion']) ? htmlspecialchars($_POST['codigoVerificacion']) : '' ?>" required>
                    <small class="form-text text-muted">Código enviado al momento de radicar</small>
                </div>
                
                <button type="submit" class="btn btn-primary btn-lg btn-block">Consultar</button>
            </form>
        </div>
        
        <?php if($error): ?>
            <div class="alert alert-danger error-alert" role="alert">
                <strong>Error:</strong> <?= htmlspecialchars($error) ?>
            </div>
        <?php endif; ?>
        
        <?php if($resultado): ?>
            <div class="success-info">
                ✓ Consulta exitosa - Radicado encontrado
            </div>
            
            <div class="table-section">
                <h3>Información del Radicado</h3>
                <table class="table table-bordered">
                    <tbody>
                        <tr>
                            <th width="30%">Número de Radicado</th>
                            <td><strong><?= htmlspecialchars($resultado['radicado']['RADI_NUME_RADI']) ?></strong></td>
                        </tr>
                        <tr>
                            <th>Fecha de Radicación</th>
                            <td><?= isset($resultado['radicado']['RADI_FECH_RADI']) ? date('d/m/Y H:i:s', strtotime($resultado['radicado']['RADI_FECH_RADI'])) : 'N/A' ?></td>
                        </tr>
                        <tr>
                            <th>Asunto</th>
                            <td><?= htmlspecialchars($resultado['radicado']['RA_ASUN'] ?? 'N/A') ?></td>
                        </tr>
                        <tr>
                            <th>Tipo de Documento</th>
                            <td><?= htmlspecialchars($resultado['radicado']['TIPO_DOC'] ?? 'N/A') ?></td>
                        </tr>
                        <tr>
                            <th>Dependencia Actual</th>
                            <td><?= htmlspecialchars($resultado['radicado']['DEPE_NOMB'] ?? 'N/A') ?></td>
                        </tr>
                        <tr>
                            <th>Usuario Actual</th>
                            <td><?= htmlspecialchars($resultado['radicado']['USUA_NOMB'] ?? 'N/A') ?></td>
                        </tr>
                        <tr>
                            <th>Estado</th>
                            <td>
                                <?php 
                                $clase = strpos($resultado['radicado']['ESTADO_LECTURA'], 'Leído') !== false ? 'status-leido' : 'status-no-leido';
                                ?>
                                <span class="status-badge <?= $clase ?>">
                                    <?= htmlspecialchars($resultado['radicado']['ESTADO_LECTURA']) ?>
                                </span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            
            <div class="table-section">
                <h3>Anexos (<?= count($resultado['anexos']) ?> archivo<?= count($resultado['anexos']) !== 1 ? 's' : '' ?>)</h3>
                <?php if(count($resultado['anexos']) > 0): ?>
                    <table class="table table-striped table-hover">
                        <thead class="table-header">
                            <tr>
                                <th>Número</th>
                                <th>Archivo</th>
                                <th>Tipo</th>
                                <th>Tamaño</th>
                                <th>Fecha de Creación</th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php foreach($resultado['anexos'] as $anexo): ?>
                                <tr>
                                    <td><?= htmlspecialchars($anexo['ANEX_NUMERO'] ?? 'N/A') ?></td>
                                    <td>
                                        <?php 
                                        $nombreArchivo = htmlspecialchars($anexo['ANEX_NOMB_ARCHIVO'] ?? 'N/A');
                                        $carpeta = htmlspecialchars($anexo['ANEX_CARPETA'] ?? '');
                                        if($carpeta && $carpeta !== 'N/A') {
                                            $rutaArchivo = '/bodega/' . trim($carpeta, '/') . '/' . basename($anexo['ANEX_NOMB_ARCHIVO'] ?? '');
                                            echo '<a href="' . htmlspecialchars($rutaArchivo) . '" target="_blank" title="Descargar ' . $nombreArchivo . '">' . $nombreArchivo . '</a>';
                                        } else {
                                            echo $nombreArchivo;
                                        }
                                        ?>
                                    </td>
                                    <td><?= htmlspecialchars($anexo['ANEX_TIPO'] ?? 'N/A') ?></td>
                                    <td>
                                        <?php 
                                        if(isset($anexo['ANEX_SIZE']) && is_numeric($anexo['ANEX_SIZE'])) {
                                            $size = $anexo['ANEX_SIZE'];
                                            if($size >= 1024*1024) {
                                                echo round($size/(1024*1024), 2) . ' MB';
                                            } elseif($size >= 1024) {
                                                echo round($size/1024, 2) . ' KB';
                                            } else {
                                                echo $size . ' bytes';
                                            }
                                        } else {
                                            echo 'N/A';
                                        }
                                        ?>
                                    </td>
                                    <td>
                                        <?php 
                                        if(isset($anexo['ANEX_FECH_CREA'])) {
                                            echo date('d/m/Y H:i:s', strtotime($anexo['ANEX_FECH_CREA']));
                                        } else {
                                            echo 'N/A';
                                        }
                                        ?>
                                    </td>
                                </tr>
                            <?php endforeach; ?>
                        </tbody>
                    </table>
                <?php else: ?>
                    <p class="text-muted">No hay anexos registrados para este radicado</p>
                <?php endif; ?>
            </div>
            
            <div style="margin-top: 30px; text-align: center;">
                <a href="consulta_simple.php" class="btn btn-outline-secondary">Nueva Consulta</a>
            </div>
        <?php endif; ?>
